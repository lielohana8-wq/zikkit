rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — each user reads/writes their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Businesses — owner reads/writes their own business
    match /businesses/{bizId} {
      allow read, write: if request.auth != null && request.auth.uid == bizId;
    }

    // Tech lookup — any auth user can read (techs find their business)
    match /tech_lookup/{lookupKey} {
      allow read, write: if request.auth != null;
    }

    // Super admins — only the admin reads their own doc
    match /super_admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Public portals — anyone can read (public links), auth users can write
    match /public_portals/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Phone lookup — voice API reads to find business by phone number
    match /phone_lookup/{phoneNumber} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Agreements — auth users can read/write
    match /agreements/{agreementId} {
      allow read, write: if request.auth != null;
    }

    // Licenses (if used)
    match /licenses/{licenseId} {
      allow read: if request.auth != null;
    }
  }
}
