rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — each user reads/writes their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Businesses — any auth user can read (techs need access), only owner writes
    match /businesses/{bizId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Tech lookup — any auth user can read/write
    match /tech_lookup/{lookupKey} {
      allow read, write: if request.auth != null;
    }

    // Super admins
    match /super_admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Public portals
    match /public_portals/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Phone lookup
    match /phone_lookup/{phoneNumber} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Agreements
    match /agreements/{agreementId} {
      allow read, write: if request.auth != null;
    }

    // Licenses
    match /licenses/{licenseId} {
      allow read: if request.auth != null;
    }
  }
}
